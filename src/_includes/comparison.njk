---
layout: base.njk
ogType: article
---

{% block schema %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "author": { "@type": "Organization", "name": "{{ site.name }}" },
  "datePublished": "{{ date | dateFormat }}",
  "dateModified": "{{ lastUpdated or date | dateFormat }}"
}
</script>
{% endblock %}

<div class="container">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a> <span>›</span>
    <a href="/comparisons/">Comparisons</a> <span>›</span>
    <span>{{ title }}</span>
  </nav>
</div>

<article class="article">
  <h1>{{ title }}</h1>
  <p class="meta">Last updated: {{ lastUpdated or date | dateFormat }}</p>

  {% if verdict %}
  <div class="info-box">
    <strong>🏆 Our Verdict:</strong> {{ verdict | safe }}
  </div>
  {% endif %}

  {{ content | safe }}

  {% if comparisonSpecs %}
  <h2>Head-to-Head Comparison</h2>
  <table class="comparison-table">
    <thead>
      <tr>
        <th>Feature</th>
        {% for product in comparisonProducts %}
        <th>{{ product }}</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for spec in comparisonSpecs %}
      <tr>
        <td><strong>{{ spec.label }}</strong></td>
        {% for val in spec.values %}
        <td>{{ val }}</td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% for product in products %}
  <h2>{{ product.name }} — Full Review</h2>
  <div class="rating">{{ product.rating | stars }} ({{ product.rating }}/5)</div>
  <div class="price">{{ product.price | gbp }}</div>
  <p>{{ product.review }}</p>
  {% if product.pros and product.cons %}
  {% proscons product.pros, product.cons %}
  {% endif %}
  {% if product.affiliateUrl %}
  {% affiliateButton product.affiliateUrl %}
  {% endif %}
  {% endfor %}

  {% if faqs %}
  <h2>FAQ</h2>
  {% for faq in faqs %}
  <div class="faq-item">
    <h3>{{ faq.q }}</h3>
    <p>{{ faq.a }}</p>
  </div>
  {% endfor %}
  {% endif %}
</article>
