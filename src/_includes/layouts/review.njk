---
layout: layouts/base.njk
ogType: article
---

{% block head %}
{# Product Review Schema #}
{% set productList = products.grainFreeDryFood if productKey == "grainFreeDryFood" else [] %}
{% if productList | length %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "{{ title }}",
  "description": "{{ description }}",
  "numberOfItems": {{ productList | length }},
  "itemListElement": [
    {% for product in productList %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "item": {
        "@type": "Product",
        "name": "{{ product.name }}",
        "brand": { "@type": "Brand", "name": "{{ product.brand }}" },
        "description": "{{ product.summary }}",
        "review": {
          "@type": "Review",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "{{ product.rating }}",
            "bestRating": "5"
          },
          "author": { "@type": "Organization", "name": "{{ site.name }}" }
        },
        "offers": {
          "@type": "Offer",
          "price": "{{ product.price }}",
          "priceCurrency": "GBP",
          "availability": "https://schema.org/InStock",
          "url": "{{ product.url }}"
        }
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

{# FAQ Schema #}
{% if faqs %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in faqs %}
    {
      "@type": "Question",
      "name": "{{ faq.q }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ faq.a }}"
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

{# Breadcrumb Schema #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
    { "@type": "ListItem", "position": 2, "name": "{{ category or 'Reviews' }}" },
    { "@type": "ListItem", "position": 3, "name": "{{ title }}" }
  ]
}
</script>
{% endblock %}

{% block content %}
<article class="article-content">
  <nav class="breadcrumbs">
    <a href="/">Home</a> › {{ category or 'Reviews' }} › {{ title }}
  </nav>

  <h1>{{ title }}</h1>
  <p class="meta" style="color: var(--color-text-light); margin-bottom: 1.5rem;">
    Last updated: {{ lastUpdated or site.lastUpdated }} · {{ readTime or '5' }} min read
  </p>

  <div class="affiliate-disclosure">
    <strong>Affiliate Disclosure:</strong> Some links on this page are affiliate links. If you buy through them, we may earn a small commission at no extra cost to you. We only recommend products we genuinely believe in. <a href="/affiliate-disclosure/">Learn more</a>.
  </div>

  {{ content | safe }}

  {% set productList = products.grainFreeDryFood if productKey == "grainFreeDryFood" else [] %}
  {% if productList | length %}
  <h2 id="our-picks">Our Top Picks — Full Reviews</h2>
  <div class="product-grid">
    {% for product in productList | sortByRating %}
    <div class="product-card" id="{{ product.slug }}">
      {% if loop.index == 1 %}<span class="badge badge--top">🏆 Top Pick</span>{% endif %}
      {% if product.bestValue %}<span class="badge badge--value">💰 Best Value</span>{% endif %}
      <h3>{{ product.name }}</h3>
      <div class="rating">{{ product.rating | stars }} ({{ product.rating }}/5)</div>
      <p class="meta">{{ product.brand }} · {{ product.weight }} · {{ product.meatContent }} meat · {{ product.protein }} protein</p>
      <p>{{ product.summary }}</p>
      <div class="pros-cons">
        <ul class="pros">
          {% for pro in product.pros %}
          <li>{{ pro }}</li>
          {% endfor %}
        </ul>
        <ul class="cons">
          {% for con in product.cons %}
          <li>{{ con }}</li>
          {% endfor %}
        </ul>
      </div>
      <p><strong>Best for:</strong> {{ product.bestFor | join(", ") }}</p>
      <div class="price">{{ product.price | gbp }} <span style="font-size: 0.85rem; font-weight: 400; color: var(--color-text-light);">({{ product.pricePerKg | gbp }}/kg)</span></div>
      <a href="{{ product.url }}" class="cta" rel="nofollow sponsored" target="_blank">Check Price on Amazon →</a>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if faqs %}
  <h2>Frequently Asked Questions</h2>
  {% for faq in faqs %}
  <details class="faq-item">
    <summary>{{ faq.q }}</summary>
    <p>{{ faq.a }}</p>
  </details>
  {% endfor %}
  {% endif %}
</article>
{% endblock %}
